# Blitz Demo Environment Variables

# Set to http://localhost:8001 for live Ogma scoring (local demo only)
# Leave unset or remove to use stub mode (no Venice credits spent)
# OGMA_URL=http://localhost:8001

# Solana keypair path for signing transactions
# Defaults to ~/.config/solana/blitz-dev.json
# SOLANA_KEYPAIR_PATH=/path/to/keypair.json

# Oracle Escrow program ID on Solana devnet
# Defaults to GyT8wyGD3dG3sVQ986SGwKxF23iWNjdbSe4oCuBrkMdd
# PROGRAM_ID=GyT8wyGD3dG3sVQ986SGwKxF23iWNjdbSe4oCuBrkMdd
